PORT=5000
NODE_ENV=development
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/careerbridge?schema=public"
JWT_ACCESS_SECRET="your_access_secret_key"
JWT_REFRESH_SECRET="your_refresh_secret_key"
JWT_ACCESS_EXPIRY="15m"
JWT_REFRESH_EXPIRY="7d"
CORS_ORIGIN="http://localhost:5173"
APP_BASE_URL="http://localhost:5000"

# --- Gemini AI -----------------------------------------------------------
# When left blank, all six AI modules (resume, career, interview, employer,
# university, admin) run in deterministic mock mode.
#
# Two key formats are supported and auto-routed to the right endpoint:
#   AIza...  -> Gemini Developer API key (aistudio.google.com/apikey)
#   AQ....   -> Vertex AI express-mode key (console.cloud.google.com/vertex-ai)
# Using either key against the wrong endpoint causes 403 "Access forbidden";
# the backend now detects the key type automatically.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
