# CareerBridge backend — PRODUCTION environment template
# Copy to your host's secret manager (Render sets most of these automatically
# via render.yaml). Never commit a filled-in copy — .env.* is gitignored.

NODE_ENV=production
PORT=10000

# From your managed Postgres (Render sets this automatically via render.yaml).
# If setting manually, use the provider's connection string.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/careerbridge

# Generate each with:  openssl rand -base64 48
# Must be >= 32 chars and NOT a known placeholder, or the app refuses to boot.
JWT_ACCESS_SECRET=__generate_a_long_random_secret__
JWT_REFRESH_SECRET=__generate_a_different_long_random_secret__
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Exact frontend origin (scheme + host, no trailing slash).
CORS_ORIGIN=https://careerbridge-web.onrender.com

# This API's own public origin (used for absolute resume/share links).
APP_BASE_URL=https://careerbridge-api-uig2.onrender.com

# AI: leave GEMINI_API_KEY unset for deterministic "Estimated" mode (fully
# usable), or set it to enable real Gemini across all six AI modules.
AI_PROVIDER=gemini
GEMINI_MODEL=gemini-flash-latest
GEMINI_ENDPOINT=auto
# GEMINI_API_KEY=

# Redis is optional — omit it and the backend uses an in-memory fallback cache.
# REDIS_URL=redis://HOST:6379
