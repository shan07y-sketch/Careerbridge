# CareerBridge backend — PRODUCTION environment template (Railway)
# Set these as variables on the Railway BACKEND service. Never commit a
# filled-in copy — .env.* is gitignored.

NODE_ENV=production

# PORT: DO NOT set manually. Railway injects PORT automatically and the app
# binds to process.env.PORT (backend/src/config/env.ts). Hardcoding it breaks
# Railway's port detection / health checks.

# DATABASE_URL: reference the Railway Postgres service instead of pasting a
# literal. In the backend service variables, set:
#   DATABASE_URL = ${{Postgres.DATABASE_URL}}
# (Railway resolves the reference to the managed Postgres connection string.)
DATABASE_URL=${{Postgres.DATABASE_URL}}

# Generate each with:  openssl rand -base64 48
# Must be >= 32 chars and NOT a known placeholder, or the app refuses to boot.
JWT_ACCESS_SECRET=__generate_a_long_random_secret__
JWT_REFRESH_SECRET=__generate_a_different_long_random_secret__
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Exact frontend origin (scheme + host, no trailing slash). Comma-separated
# list is supported. Set to the FRONTEND service's public Railway domain, e.g.
#   https://careerbridge-web-production.up.railway.app
# The backend ALSO always allows the Capacitor origins (https://localhost,
# capacitor://localhost) for the Android app — no need to add them here.
CORS_ORIGIN=https://REPLACE-WITH-RAILWAY-FRONTEND-DOMAIN

# This API's own public origin (used for absolute resume/share links). Set to
# the BACKEND service's public Railway domain.
APP_BASE_URL=https://REPLACE-WITH-RAILWAY-BACKEND-DOMAIN

# AI: leave GEMINI_API_KEY unset for deterministic "Estimated" mode (fully
# usable), or set it to enable real Gemini across all six AI modules.
AI_PROVIDER=gemini
GEMINI_MODEL=gemini-flash-latest
GEMINI_ENDPOINT=auto
# GEMINI_API_KEY=

# Redis is optional — omit it and the backend uses an in-memory fallback cache.
# To add one, provision a Railway Redis service and set:
#   REDIS_URL=${{Redis.REDIS_URL}}
