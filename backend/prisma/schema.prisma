generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                     String                  @id @default(uuid())
  email                  String                  @unique
  passwordHash           String
  role                   UserRole
  isVerified             Boolean                 @default(false)
  verificationToken      String?
  resetToken             String?
  resetTokenExpiry       DateTime?
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  isDeleted              Boolean                 @default(false)
  deletedAt              DateTime?
  companyId              String?
  lastLoginAt            DateTime?
  auditLogs              AuditLog[]
  receivedNotifications  Notification[]          @relation("NotificationRecipient")
  sentNotifications      Notification[]          @relation("NotificationSender")
  announcements          PlatformAnnouncement[]
  platformInsightReports PlatformInsightReport[]
  recruiterProfile       Recruiter?
  refreshTokens          RefreshToken[]
  studentProfile         StudentProfile?
  companyRatings         CompanyRating[]
  supportTicketsAssigned SupportTicket[]         @relation("SupportTicketAssignee")
  supportTicketsFiled    SupportTicket[]         @relation("SupportTicketRequester")
  universityProfile      University?
  company                Company?                @relation(fields: [companyId], references: [id])

  @@index([email])
  @@index([companyId])
}

model RefreshToken {
  id              String    @id @default(uuid())
  token           String    @unique
  userId          String
  expiresAt       DateTime
  createdAt       DateTime  @default(now())
  isRevoked       Boolean   @default(false)
  family          String    @default(uuid())
  replacedByToken String?
  revokedAt       DateTime?
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([family])
}

model StudentProfile {
  id                       String                    @id @default(uuid())
  userId                   String                    @unique
  firstName                String
  lastName                 String
  phone                    String?
  avatarUrl                String?
  bio                      String?
  currentGpa               Float?
  universityId             String?
  departmentId             String?
  graduationYear           Int?
  preferredRole            String?
  preferredWorkMode        WorkMode?
  preferredLocations       String[]
  // AI Preferences (Settings tab): minimal additive fields -- the Settings
  // page collected these but had nowhere real to save them before.
  careerPath               String?
  targetCompanies          String?
  targetSalaryRange        String?
  jobTypePreference        String?                   @default("Full-Time")
  preferredIndustries      String[]                  @default([])
  recommendationFrequency  String?                   @default("Daily")
  createdAt                DateTime                  @default(now())
  updatedAt                DateTime                  @updatedAt
  verificationStatus       VerificationStatus        @default(PENDING)
  aiConversations          AiConversation[]
  applications             Application[]
  careerInsights           CareerInsight[]
  certifications           Certification[]
  connectionsReceived      Connection[]              @relation("ConnectionReceiver")
  connectionsSent          Connection[]              @relation("ConnectionSender")
  conversationParticipants ConversationParticipant[]
  educationHistory         Education[]
  eventRegistrations       EventRegistration[]
  experienceHistory        Experience[]
  mentorProfile            Mentor?
  mentorBookings           MentorBooking[]
  messages                 Message[]
  mockInterviews           MockInterview[]
  projects                 Project[]
  resumes                  Resume[]
  resumeAnalyses           ResumeAnalysis[]
  savedJobs                SavedJob[]
  placementInsights        StudentPlacementInsight[]
  department               Department?               @relation(fields: [departmentId], references: [id])
  university               University?               @relation(fields: [universityId], references: [id])
  user                     User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  skills                   StudentSkill[]

  @@index([universityId])
  @@index([graduationYear])
}

model Education {
  id               String         @id @default(uuid())
  studentProfileId String
  institution      String
  degree           String
  fieldOfStudy     String
  startDate        DateTime
  endDate          DateTime?
  gpa              Float?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  studentProfile   StudentProfile @relation(fields: [studentProfileId], references: [id], onDelete: Cascade)
}

model Experience {
  id               String         @id @default(uuid())
  studentProfileId String
  companyName      String
  roleTitle        String
  employmentType   String?
  startDate        DateTime
  endDate          DateTime?
  isCurrent        Boolean        @default(false)
  description      String?
  location         String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  studentProfile   StudentProfile @relation(fields: [studentProfileId], references: [id], onDelete: Cascade)
}

model Project {
  id               String         @id @default(uuid())
  studentProfileId String
  title            String
  description      String
  linkUrl          String?
  repoUrl          String?
  startDate        DateTime?
  endDate          DateTime?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  studentProfile   StudentProfile @relation(fields: [studentProfileId], references: [id], onDelete: Cascade)
}

model Certification {
  id               String         @id @default(uuid())
  studentProfileId String
  name             String
  issuingOrg       String
  issueDate        DateTime
  expiryDate       DateTime?
  credentialId     String?
  credentialUrl    String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  studentProfile   StudentProfile @relation(fields: [studentProfileId], references: [id], onDelete: Cascade)
}

model Skill {
  id            String         @id @default(uuid())
  name          String         @unique
  createdAt     DateTime       @default(now())
  jobSkills     JobSkill[]
  studentSkills StudentSkill[]

  @@index([name])
}

model StudentSkill {
  studentProfileId String
  skillId          String
  level            Int            @default(50)
  skill            Skill          @relation(fields: [skillId], references: [id], onDelete: Cascade)
  studentProfile   StudentProfile @relation(fields: [studentProfileId], references: [id], onDelete: Cascade)

  @@id([studentProfileId, skillId])
}

model Resume {
  id               String           @id @default(uuid())
  studentProfileId String
  fileName         String
  fileUrl          String
  status           ResumeStatus     @default(PROCESSING)
  parsedText       String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  version          Int              @default(1)
  isActive         Boolean          @default(true)
  fileSizeBytes    Int?
  mimeType         String?
  extractedSkills  String[]         @default([])
  shareToken       String?          @unique
  shareEnabled     Boolean          @default(false)
  shareExpiresAt   DateTime?
  studentProfile   StudentProfile   @relation(fields: [studentProfileId], references: [id], onDelete: Cascade)
  resumeAnalyses   ResumeAnalysis[]

  @@index([studentProfileId, isActive])
}

model Company {
  id              String      @id @default(uuid())
  name            String      @unique
  logoUrl         String?
  website         String?
  industry        String
  description     String
  size            Int?
  headquarters    String?
  // Company Profile tab (Employer Portal) -- added so every field the
  // profile editor exposes is backed by a real, persisted column instead
  // of local component state. Kept as plain scalars/JSON rather than new
  // relational models since none of this needs independent querying.
  coverImageUrl   String?
  missionValues   String[]    @default([])
  techStack       String[]    @default([])
  galleryImages   String[]    @default([])
  officeLocations Json        @default("[]")
  screenedTarget  Int         @default(100)
  outreachTarget  Int         @default(20)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  isDeleted       Boolean     @default(false)
  deletedAt       DateTime?
  isVerified      Boolean     @default(false)
  verifiedAt      DateTime?
  jobs            Job[]
  recruiters      Recruiter[]
  tags            Tag[]
  users           User[]
  ratings         CompanyRating[]

  @@index([name])
}

// Real company reviews/ratings. Company directory computes its average from
// these rows; when a company has none, the API honestly returns 0 (unrated).
model CompanyRating {
  id        String   @id @default(uuid())
  companyId String
  authorId  String
  score     Int
  review    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@unique([companyId, authorId])
  @@index([companyId])
}

model Recruiter {
  id                       String                    @id @default(uuid())
  userId                   String                    @unique
  companyId                String
  title                    String
  phone                    String?
  // No name field exists anywhere for a recruiter today: User only has
  // email/role (see model User above), and registerUser() was silently
  // discarding the firstName/lastName it already collects at signup for
  // every other role. StudentProfile and University both have their own
  // name storage; Recruiter genuinely had none, so the Team/Recruiters tab
  // could not display who anyone is without this. Nullable because
  // existing recruiter rows (created before this migration) have no value.
  firstName                String?
  lastName                 String?
  createdAt                DateTime                  @default(now())
  updatedAt                DateTime                  @updatedAt
  notes                    ApplicationNote[]
  scheduledInterviews      Interview[]
  jobs                     Job[]
  offers                   Offer[]
  company                  Company                   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user                     User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  savedFilters             SavedFilter[]
  conversationParticipants ConversationParticipant[]
  sentMessages             Message[]
}

model University {
  id              String           @id @default(uuid())
  userId          String           @unique
  name            String           @unique
  logoUrl         String?
  location        String
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  isDeleted       Boolean          @default(false)
  deletedAt       DateTime?
  isVerified      Boolean          @default(false)
  verifiedAt      DateTime?
  departments     Department[]
  placementCells  PlacementCell[]
  placementDrives PlacementDrive[]
  students        StudentProfile[]
  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([name])
}

/// *
///  * Real campus recruitment drive scheduled by a university's placement cell.
///  * Replaces the earlier approach of encoding drive metadata into an Event's
///  * title string -- a real column-backed model so drives can be queried,
///  * indexed, and validated like any other first-class entity.
model PlacementDrive {
  id           String     @id @default(uuid())
  universityId String
  title        String
  description  String
  location     String
  scheduledAt  DateTime
  deadline     DateTime
  isDeleted    Boolean    @default(false)
  deletedAt    DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  university   University @relation(fields: [universityId], references: [id], onDelete: Cascade)

  @@index([universityId])
}

model Department {
  id           String           @id @default(uuid())
  universityId String
  name         String
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  university   University       @relation(fields: [universityId], references: [id], onDelete: Cascade)
  students     StudentProfile[]

  @@unique([universityId, name])
}

model PlacementCell {
  id           String     @id @default(uuid())
  universityId String
  directorName String
  contactEmail String
  phone        String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  university   University @relation(fields: [universityId], references: [id], onDelete: Cascade)
}

model JobCategory {
  id        String   @id @default(uuid())
  name      String   @unique
  createdAt DateTime @default(now())
  jobs      Job[]
}

model Job {
  id              String        @id @default(uuid())
  companyId       String
  recruiterId     String
  categoryId      String
  title           String
  description     String
  requirements    String
  benefits        String?
  location        String
  jobType         JobType
  workMode        WorkMode
  salaryMin       Float?
  salaryMax       Float?
  currency        String        @default("USD")
  deadline        DateTime?
  isPublished     Boolean       @default(true)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  isDeleted       Boolean       @default(false)
  deletedAt       DateTime?
  status          JobStatus     @default(DRAFT)
  applications    Application[]
  category        JobCategory   @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  company         Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  recruiter       Recruiter     @relation(fields: [recruiterId], references: [id], onDelete: Cascade)
  skillsRequired  JobSkill[]
  savedByStudents SavedJob[]
  mockInterviews  MockInterview[]

  @@index([title])
  @@index([companyId])
  @@index([categoryId])
}

model JobSkill {
  jobId   String
  skillId String
  job     Job    @relation(fields: [jobId], references: [id], onDelete: Cascade)
  skill   Skill  @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@id([jobId, skillId])
}

model SavedJob {
  studentProfileId String
  jobId            String
  createdAt        DateTime       @default(now())
  job              Job            @relation(fields: [jobId], references: [id], onDelete: Cascade)
  studentProfile   StudentProfile @relation(fields: [studentProfileId], references: [id], onDelete: Cascade)

  @@id([studentProfileId, jobId])
}

model Application {
  id                   String                @id @default(uuid())
  studentProfileId     String
  jobId                String
  status               ApplicationStatus     @default(APPLIED)
  coverLetter          String?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  job                  Job                   @relation(fields: [jobId], references: [id], onDelete: Cascade)
  studentProfile       StudentProfile        @relation(fields: [studentProfileId], references: [id], onDelete: Cascade)
  notes                ApplicationNote[]
  stages               ApplicationStage[]
  tags                 ApplicationTag[]
  candidateEvaluations CandidateEvaluation[]
  interviews           Interview[]
  offer                Offer?

  @@unique([studentProfileId, jobId])
  @@index([status])
}

/// Employer AI (Phase 4): an AI-generated fit evaluation of a candidate's
/// application against its job, reusing the same Resume Intelligence
/// (Phase 1) and Mock Interview AI (Phase 2) signals Career Intelligence
/// already reads. Kept as a history (not unique per application) so a
/// recruiter can re-run the evaluation as the candidate's resume/interview
/// history changes and see how the read evolved; callers fetch the latest
/// row via `orderBy: { createdAt: 'desc' }, take: 1`.
model CandidateEvaluation {
  id              String      @id @default(uuid())
  applicationId   String
  fitScore        Int
  recommendation  String
  summary         String
  strengths       String[]    @default([])
  concerns        String[]    @default([])
  skillsMatch     String[]    @default([])
  skillsGap       String[]    @default([])
  interviewSignal String?
  modelVersion    String
  createdAt       DateTime    @default(now())
  application     Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([applicationId])
}

/// University AI (Phase 5): an AI-generated placement prediction and risk
/// assessment for a student, reusing the same Resume Intelligence (Phase 1)
/// and Mock Interview AI (Phase 2) signals Career Intelligence and Employer AI
/// already read, plus the student's own academic data. Kept as a history (not
/// unique per student) so the placement cell can re-run the assessment as the
/// student's resume/interview/skill data evolves; callers fetch the latest
/// row via `orderBy: { createdAt: 'desc' }, take: 1`.
model StudentPlacementInsight {
  id                   String         @id @default(uuid())
  studentProfileId     String
  placementProbability Int
  riskLevel            String
  summary              String
  riskFactors          String[]       @default([])
  strengths            String[]       @default([])
  suggestedActions     String[]       @default([])
  modelVersion         String
  createdAt            DateTime       @default(now())
  studentProfile       StudentProfile @relation(fields: [studentProfileId], references: [id], onDelete: Cascade)

  @@index([studentProfileId])
}

model ApplicationStage {
  id            String            @id @default(uuid())
  applicationId String
  stageName     String
  status        ApplicationStatus
  notes         String?
  completedAt   DateTime?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  application   Application       @relation(fields: [applicationId], references: [id], onDelete: Cascade)
}

model Interview {
  id                     String          @id @default(uuid())
  applicationId          String
  title                  String
  scheduledAt            DateTime
  duration               Int
  locationUrl            String?
  status                 InterviewStatus @default(SCHEDULED)
  feedback               String?
  createdAt              DateTime        @default(now())
  updatedAt              DateTime        @updatedAt
  scheduledByRecruiterId String?
  application            Application     @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  scheduledByRecruiter   Recruiter?      @relation(fields: [scheduledByRecruiterId], references: [id])

  @@index([scheduledAt])
}

/// *
///  * A single internal note thread per application. "Recruiter notes" and
///  * "internal comments" are the same concept in this context -- candidates
///  * never see either -- so they're modeled as one thread rather than two
///  * duplicate features with identical shape and access rules.
model ApplicationNote {
  id                String      @id @default(uuid())
  applicationId     String
  authorRecruiterId String
  content           String
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  application       Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  authorRecruiter   Recruiter   @relation(fields: [authorRecruiterId], references: [id], onDelete: Cascade)

  @@index([applicationId])
}

model Offer {
  id                   String      @id @default(uuid())
  applicationId        String      @unique
  createdByRecruiterId String
  title                String
  salary               Float
  currency             String      @default("USD")
  startDate            DateTime
  notes                String?
  status               OfferStatus @default(DRAFT)
  extendedAt           DateTime?
  respondedAt          DateTime?
  withdrawnAt          DateTime?
  createdAt            DateTime    @default(now())
  updatedAt            DateTime    @updatedAt
  application          Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  createdByRecruiter   Recruiter   @relation(fields: [createdByRecruiterId], references: [id], onDelete: Cascade)
}

/// *
///  * Company-scoped labels a recruiter can attach to an application (e.g.
///  * "Top Talent", "Needs Follow-up"). Scoped to the company, not the individual
///  * recruiter, so any recruiter on the team sees and can reuse the same tags.
model Tag {
  id           String           @id @default(uuid())
  companyId    String
  name         String
  color        String?
  createdAt    DateTime         @default(now())
  applications ApplicationTag[]
  company      Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, name])
  @@index([companyId])
}

model ApplicationTag {
  applicationId String
  tagId         String
  createdAt     DateTime    @default(now())
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  tag           Tag         @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([applicationId, tagId])
  @@index([tagId])
}

/// *
///  * A recruiter's personal saved search/filter combination for the candidate
///  * queue (status, job, date range, tags, sort). Scoped to the recruiter, not
///  * the company: filter presets reflect an individual's workflow (e.g. "my
///  * queue of senior candidates awaiting review") and sharing them company-wide
///  * would require a separate "shared preset" concept we don't have a concrete
///  * use case for yet -- easy to add later without a breaking change.
model SavedFilter {
  id          String    @id @default(uuid())
  recruiterId String
  name        String
  filters     Json
  createdAt   DateTime  @default(now())
  recruiter   Recruiter @relation(fields: [recruiterId], references: [id], onDelete: Cascade)

  @@index([recruiterId])
}

model Connection {
  id         String           @id @default(uuid())
  senderId   String
  receiverId String
  status     ConnectionStatus @default(PENDING)
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt
  receiver   StudentProfile   @relation("ConnectionReceiver", fields: [receiverId], references: [id], onDelete: Cascade)
  sender     StudentProfile   @relation("ConnectionSender", fields: [senderId], references: [id], onDelete: Cascade)

  @@unique([senderId, receiverId])
}

model Mentor {
  id               String          @id @default(uuid())
  studentProfileId String          @unique
  expertise        String[]
  jobTitle         String
  companyName      String
  bio              String
  rating           Float           @default(5.0)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  studentProfile   StudentProfile  @relation(fields: [studentProfileId], references: [id], onDelete: Cascade)
  bookings         MentorBooking[]
  availability     MentorAvailability[]
}

// Real, bookable availability slots for a mentor. Ecosystem discovery
// (student MentorProfile) renders these instead of fabricated slots.
model MentorAvailability {
  id        String   @id @default(uuid())
  mentorId  String
  startTime DateTime
  endTime   DateTime
  isBooked  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  mentor    Mentor   @relation(fields: [mentorId], references: [id], onDelete: Cascade)

  @@index([mentorId, startTime])
}

model MentorBooking {
  id               String         @id @default(uuid())
  mentorId         String
  studentProfileId String
  scheduledAt      DateTime
  duration         Int            @default(45)
  topic            String
  meetingUrl       String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  mentor           Mentor         @relation(fields: [mentorId], references: [id], onDelete: Cascade)
  studentProfile   StudentProfile @relation(fields: [studentProfileId], references: [id], onDelete: Cascade)
}

model Conversation {
  id           String                    @id @default(uuid())
  createdAt    DateTime                  @default(now())
  updatedAt    DateTime                  @updatedAt
  participants ConversationParticipant[]
  messages     Message[]
}

// A participant is either a student or a recruiter -- never both, never
// neither (enforced in MessagesRepository, not the DB, to avoid a CHECK
// constraint migration). recruiterId/studentProfileId were both made
// nullable so the *same* Conversation/Message tables serve both the
// existing student<->student networking chat and the new Employer
// Messaging tab, instead of standing up a parallel messaging system.
model ConversationParticipant {
  id               String          @id @default(uuid())
  conversationId   String
  studentProfileId String?
  recruiterId      String?
  joinedAt         DateTime        @default(now())
  conversation     Conversation    @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  studentProfile   StudentProfile? @relation(fields: [studentProfileId], references: [id], onDelete: Cascade)
  recruiter        Recruiter?      @relation(fields: [recruiterId], references: [id], onDelete: Cascade)

  @@unique([conversationId, studentProfileId])
  @@unique([conversationId, recruiterId])
}

model Message {
  id                String          @id @default(uuid())
  conversationId    String
  senderId          String?
  senderRecruiterId String?
  content           String
  status            MessageStatus   @default(SENT)
  createdAt         DateTime        @default(now())
  conversation      Conversation    @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender            StudentProfile? @relation(fields: [senderId], references: [id], onDelete: Cascade)
  senderRecruiter   Recruiter?      @relation(fields: [senderRecruiterId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([createdAt])
}

model Notification {
  id          String               @id @default(uuid())
  senderId    String?
  recipientId String
  type        NotificationType
  priority    NotificationPriority @default(MEDIUM)
  title       String
  content     String
  isRead      Boolean              @default(false)
  linkUrl     String?
  createdAt   DateTime             @default(now())
  recipient   User                 @relation("NotificationRecipient", fields: [recipientId], references: [id], onDelete: Cascade)
  sender      User?                @relation("NotificationSender", fields: [senderId], references: [id])

  @@index([recipientId])
  @@index([isRead])
}

model CareerInsight {
  id                         String         @id @default(uuid())
  studentProfileId           String
  summary                    String
  score                      Int
  status                     String
  modelVersion               String
  generatedAt                DateTime       @default(now())
  createdAt                  DateTime       @default(now())
  updatedAt                  DateTime       @updatedAt
  targetRole                 String?
  readinessPercent           Int?
  whyThisScore               String?
  matchedSkills              String[]       @default([])
  missingSkills              String[]       @default([])
  recommendedProjects        String[]       @default([])
  recommendedCourses         String[]       @default([])
  recommendedInterviewTopics String[]       @default([])
  /// Array of {title, description} roadmap steps, stored as JSON since the
  /// step count/shape is AI-generated rather than a fixed schema.
  roadmap                    Json?
  studentProfile             StudentProfile @relation(fields: [studentProfileId], references: [id], onDelete: Cascade)
}

model ResumeAnalysis {
  id               String         @id @default(uuid())
  studentProfileId String
  resumeId         String
  summary          String
  score            Int
  status           String
  modelVersion     String
  generatedAt      DateTime       @default(now())
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  resume           Resume         @relation(fields: [resumeId], references: [id], onDelete: Cascade)
  studentProfile   StudentProfile @relation(fields: [studentProfileId], references: [id], onDelete: Cascade)
}

model MockInterview {
  id                String                 @id @default(uuid())
  studentProfileId  String
  jobTitle          String
  durationLimit     Int                    @default(30)
  createdAt         DateTime               @default(now())
  targetRole        String?
  numQuestions      Int                    @default(6)
  status            InterviewSessionStatus @default(IN_PROGRESS)
  aiEngineSessionId String?
  completedAt       DateTime?
  /// Interview configuration chosen at setup time.
  interviewType     MockInterviewType      @default(MIXED)
  difficulty        InterviewDifficulty    @default(MEDIUM)
  /// Optional real job this practice session targets (drives job-match scoring).
  jobId             String?
  companyName       String?
  /// DB-backed session state: the AI-generated question plan (remaining
  /// planned questions + adaptive state). Replaces the old in-memory Map so
  /// sessions survive restarts and scale horizontally.
  questionPlan      Json?
  /// Snapshot of the student/job context the plan was generated from, so the
  /// final report is traceable to exactly what the AI saw.
  contextSnapshot   Json?
  /// Observable camera/participation events reported by the client
  /// ({at, type, detail}). Events only -- never fraud/cheating claims.
  cameraObservations Json                  @default("[]")
  /// True when the question plan came from the deterministic fallback
  /// rather than Gemini.
  planEstimated     Boolean                @default(false)
  totalDurationSec  Int?
  /// Student opt-in: employers with an application from this student may
  /// view the final report.
  sharedWithEmployers Boolean              @default(false)
  sharedAt          DateTime?
  job               Job?                   @relation(fields: [jobId], references: [id])
  questions         InterviewQuestion[]
  studentProfile    StudentProfile         @relation(fields: [studentProfileId], references: [id], onDelete: Cascade)
  reports           MockInterviewReport[]

  @@index([studentProfileId, status])
}

/// One row per question asked during a mock interview session -- the
/// full per-question Q&A trail (transcript, recorded clip references, and
/// per-answer AI evaluation) that the final MockInterviewReport is
/// synthesized from.
model InterviewQuestion {
  id                    String        @id @default(uuid())
  mockInterviewId       String
  questionIndex         Int
  questionType          String
  questionText          String
  answerTranscript      String?
  audioUrl              String?
  videoUrl              String?
  wordsPerMinute        Float?
  fillerWordCount       Int?
  eyeContactPercent     Float?
  smileFrequencyPercent Float?
  postureScore          Float?
  headMovementScore     Float?
  answerQualityScore    Int?
  technicalAccuracy     Int?
  grammarScore          Int?
  feedback              String?
  strengths             String[]      @default([])
  weaknesses            String[]      @default([])
  createdAt             DateTime      @default(now())
  /// Difficulty this question was asked at (adaptive engine may raise or
  /// lower it relative to the session default).
  difficulty            String?
  /// Skills the question is probing for, from the AI question plan.
  expectedSkills        String[]      @default([])
  /// How the answer was captured: 'voice' (speech-to-text) or 'text' (typed fallback).
  answerMethod          String?
  answerDurationSec     Float?
  askedAt               DateTime?
  answeredAt            DateTime?
  communicationScore    Int?
  problemSolvingScore   Int?
  relevanceScore        Int?
  completenessScore     Int?
  suggestedBetterAnswer String?
  /// True when this answer's evaluation came from the deterministic
  /// fallback, not Gemini.
  evaluationEstimated   Boolean       @default(false)
  mockInterview         MockInterview @relation(fields: [mockInterviewId], references: [id], onDelete: Cascade)

  @@unique([mockInterviewId, questionIndex])
}

model MockInterviewReport {
  id                    String        @id @default(uuid())
  mockInterviewId       String
  summary               String
  score                 Int
  status                String
  modelVersion          String
  generatedAt           DateTime      @default(now())
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt
  technicalScore        Int?
  hrScore               Int?
  communicationScore    Int?
  confidenceScore       Int?
  grammarScore          Int?
  answerQualityScore    Int?
  eyeContactPercent     Float?
  smileFrequencyPercent Float?
  bodyLanguageScore     Float?
  headMovementScore     Float?
  speakingSpeedWpm      Float?
  fillerWordCount       Int?
  improvementPlan       String[]      @default([])
  suggestedCourses      String[]      @default([])
  suggestedQuestions    String[]      @default([])
  aiSummary             String?
  behavioralScore       Int?
  problemSolvingScore   Int?
  /// 0-100 readiness for real interviews at this difficulty/role.
  interviewReadiness    Int?
  /// Fit vs the targeted job (only meaningful when a job was selected).
  jobMatchPercent       Int?
  skillMatchPercent     Int?
  strengths             String[]      @default([])
  weaknesses            String[]      @default([])
  missingSkills         String[]      @default([])
  /// Ordered learning roadmap steps: [{step, title, description, resources[]}].
  learningRoadmap       Json          @default("[]")
  recommendedProjects   String[]      @default([])
  recommendedCertifications String[]  @default([])
  careerRecommendations String[]      @default([])
  /// Frozen per-question breakdown snapshot so every surface (dashboard,
  /// employer, university, PDF) renders the exact same values.
  questionBreakdown     Json          @default("[]")
  /// Aggregated observable camera events ({event, count}) -- events only.
  cameraSummary         Json?
  /// True when qualitative sections were produced by the offline fallback.
  /// Surfaces as "Estimated – AI unavailable" and must never be presented
  /// as Gemini output.
  estimated             Boolean       @default(false)
  pdfUrl                String?
  mockInterview         MockInterview @relation(fields: [mockInterviewId], references: [id], onDelete: Cascade)
}

model Event {
  id            String              @id @default(uuid())
  title         String
  description   String
  location      String
  scheduledAt   DateTime
  deadline      DateTime
  maxSeats      Int?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  isDeleted     Boolean             @default(false)
  deletedAt     DateTime?
  registrations EventRegistration[]

  @@index([scheduledAt])
}

model EventRegistration {
  id               String         @id @default(uuid())
  eventId          String
  studentProfileId String
  registeredAt     DateTime       @default(now())
  event            Event          @relation(fields: [eventId], references: [id], onDelete: Cascade)
  studentProfile   StudentProfile @relation(fields: [studentProfileId], references: [id], onDelete: Cascade)

  @@unique([eventId, studentProfileId])
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  action    String
  ipAddress String?
  details   String?
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id])
}

/// Admin AI (Phase 6): a single generic history table for every Admin AI
/// report type (fraud detection, platform insights, moderation
/// recommendations, system health, executive reports, predictive analytics)
/// rather than six near-identical models -- `reportType` discriminates which
/// kind of report a row is, and `payload` holds that report's full JSON
/// response shape exactly as returned by the ai-engine. Kept as a history
/// (not unique per type) so an admin can re-run any report and see how it
/// evolved; callers fetch the latest row for a type via
/// `orderBy: { createdAt: 'desc' }, take: 1`.
model PlatformInsightReport {
  id           String   @id @default(uuid())
  reportType   String
  payload      Json
  modelVersion String
  generatedBy  String?
  createdAt    DateTime @default(now())
  generator    User?    @relation(fields: [generatedBy], references: [id])

  @@index([reportType])
}

model FeatureFlag {
  id          String   @id @default(uuid())
  key         String   @unique
  value       Boolean  @default(false)
  description String
  updatedBy   String?
  updatedAt   DateTime @updatedAt
  createdAt   DateTime @default(now())
}

/// Platform-wide announcement banner authored by an admin. Columns match
/// migrations 20260716070000_feature_flags_announcements +
/// 20260717112030_npx_prisma_db_pull (which dropped `title`). This model
/// (and SupportTicket below) was reconstructed after the tail of this file
/// was accidentally truncated mid-model.
model PlatformAnnouncement {
  id        String    @id @default(uuid())
  title     String    @default("")
  content   String
  severity  String    @default("info")
  isActive  Boolean   @default(true)
  createdBy String?
  expiresAt DateTime?
  createdAt DateTime  @default(now())
  creator   User?     @relation(fields: [createdBy], references: [id])
}

/// Support ticket filed from any portal; worked by admins in the Command
/// Center. Columns match migration 20260716080000_support_tickets.
model SupportTicket {
  id             String    @id @default(uuid())
  subject        String
  message        String
  status         String    @default("OPEN")
  priority       String    @default("NORMAL")
  requesterId    String?
  requesterEmail String
  requesterRole  String
  assignedToId   String?
  resolutionNote String?
  resolvedAt     DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  requester      User?     @relation("SupportTicketRequester", fields: [requesterId], references: [id])
  assignedTo     User?     @relation("SupportTicketAssignee", fields: [assignedToId], references: [id])

  @@index([status])
}

