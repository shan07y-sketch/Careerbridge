# CareerBridge frontend — PRODUCTION environment template
# Used at BUILD time by Vite. On Render this is set via render.yaml.
# For a local production build (e.g. before building the Android APK):
#   copy this to .env.production and run `npm run build`.

# Backend ORIGIN only — do NOT append /api/v1 (the app adds it itself).
# Also used for the Socket.IO realtime connection.
VITE_API_URL=https://careerbridge-api.onrender.com
