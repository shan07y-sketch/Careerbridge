# CareerBridge frontend — PRODUCTION environment template (Railway)
# VITE_API_URL is a BUILD-time variable read by Vite. On Railway, set it as a
# variable on the FRONTEND service so it is present during the build.
#
# For a local production build (e.g. before building the Android APK):
#   copy this to .env.production and run `npm run build`.

# Backend PUBLIC Railway origin — do NOT append /api/v1 (the app adds it).
# Also used for the Socket.IO realtime connection. Replace with the real
# domain Railway assigns the backend service (Settings -> Networking ->
# Public Networking -> Generate Domain), e.g.
#   https://careerbridge-api-production.up.railway.app
VITE_API_URL=https://REPLACE-WITH-RAILWAY-BACKEND-DOMAIN
