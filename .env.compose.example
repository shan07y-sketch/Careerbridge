# Template for docker-compose secrets.
#
# Copy this file to `.env` in the same directory as docker-compose.yml
# (that file is already gitignored — see .gitignore). docker-compose reads
# `.env` automatically; the values below are substituted into
# docker-compose.yml at `docker-compose up` time.
#
# Generate strong secrets with, e.g.:
#   openssl rand -base64 48
#
# Never reuse the example/placeholder values below in any real environment.

POSTGRES_USER=careerbridge
POSTGRES_PASSWORD=replace_with_a_long_random_value
POSTGRES_DB=careerbridge

JWT_ACCESS_SECRET=replace_with_output_of__openssl_rand_base64_48
JWT_REFRESH_SECRET=replace_with_a_different_output_of__openssl_rand_base64_48
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

CORS_ORIGIN=https://your-production-domain.example.com
CLOUDINARY_URL=

# --- Gemini AI (Google Generative Language API) --------------------------
# All six AI modules (resume, career, interview, employer, university,
# admin) run in deterministic mock mode when this is left blank.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
