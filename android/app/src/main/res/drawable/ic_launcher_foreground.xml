<?xml version="1.0" encoding="utf-8"?>
<!--
    CareerBridge adaptive-icon foreground: the bridge glyph.

    Authored as a VectorDrawable rather than a set of density-bucketed PNGs so
    the mark stays crisp on every screen and ships as one small asset. The art
    is drawn in a 48x48 space and scaled into the 108x108 adaptive viewport,
    kept inside the 72dp safe zone so no launcher mask clips it.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">
    <group
        android:scaleX="1.1"
        android:scaleY="1.1"
        android:translateX="27.6"
        android:translateY="27.6">
        <!-- Suspension arch -->
        <path
            android:pathData="M10,33 Q24,11 38,33"
            android:strokeColor="#E8B44A"
            android:strokeWidth="3.4"
            android:strokeLineCap="round" />
        <!-- Deck -->
        <path
            android:pathData="M8,33 H40"
            android:strokeColor="#FFFFFF"
            android:strokeWidth="3.4"
            android:strokeLineCap="round" />
        <!-- Hangers -->
        <path
            android:pathData="M15.5,26.4 V33"
            android:strokeColor="#FFFFFF"
            android:strokeAlpha="0.55"
            android:strokeWidth="2"
            android:strokeLineCap="round" />
        <path
            android:pathData="M32.5,26.4 V33"
            android:strokeColor="#FFFFFF"
            android:strokeAlpha="0.55"
            android:strokeWidth="2"
            android:strokeLineCap="round" />
        <!-- Apex node -->
        <path
            android:pathData="M24,12.8 a3.6,3.6 0 1,0 0.01,0 z"
            android:fillColor="#FFFFFF" />
    </group>
</vector>
